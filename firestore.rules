rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Base rule: Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if user is accessing their own data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId);
      // No deletion allowed from client
    }
    
    // Progress collection
    match /progress/{progressId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }
    
    // Quizzes collection
    match /quizzes/{quizId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // Chats collection
    match /chats/{chatId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
    }
    
    // Notes collection
    match /notes/{noteId} {
      allow read, write: if isOwner(resource.data.userId) || isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow read: if isOwner(resource.data.userId);
      // Usually written via backend webhook
    }
  }
}
