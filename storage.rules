rules_version = '2';

// Craft rules based on the provided logic.
// Authenticated users can read and write to their own specific paths.
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // User profile images
    match /users/{userId}/profile.png {
      allow read: if request.auth != null; // Public to all authenticated users
      allow write: if request.auth != null 
                   && request.auth.uid == userId 
                   && request.resource.size < 5 * 1024 * 1024 // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }

    // User study attachments (if any)
    match /users/{userId}/attachments/{fileName} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
